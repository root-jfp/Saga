# Book Reader Microservice — Environment Variables
# Copy this file to .env and fill in your values.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=book_reader
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string

# ── Audio Worker ──────────────────────────────────────────────────────────────
# Seconds between queue polls (default: 2)
AUDIO_WORKER_POLL_INTERVAL=2

# Max retry attempts per failed job (default: 3)
AUDIO_WORKER_MAX_RETRIES=3

# Parallel TTS jobs (default: 4)
AUDIO_WORKER_CONCURRENCY=4
